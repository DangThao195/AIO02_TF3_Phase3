{
  "__comment": "AI Engine Health dashboard (C1.6). Import into Grafana; datasource=Prometheus. UID ai-engine-health. Shows pipeline liveness, alert volume, detector/gateway health, guardrail, and weekly AI cost budget. All exprs use metrics emitted by src/ai_engine/common/metrics.py.",
  "uid": "ai-engine-health",
  "title": "TF3 · AI Engine Health",
  "tags": ["tf3", "ai-engine", "aiops", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat", "title": "Engine blind? (0=seeing, 1=blind)",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": {
        "unit": "none", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 } ] } } },
      "targets": [ { "expr": "max(ai_engine_blind)", "legendFormat": "blind" } ]
    },
    {
      "type": "stat", "title": "Circuit breaker (0=closed 1=half 2=open)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": {
        "unit": "none", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 1 },
          { "color": "red", "value": 2 } ] } } },
      "targets": [ { "expr": "max(ai_breaker_state)", "legendFormat": "state" } ]
    },
    {
      "type": "stat", "title": "Alerts / hour (storm > 20 → digest)",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": {
        "unit": "none", "decimals": 0,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 20 } ] } } },
      "targets": [ { "expr": "sum(increase(ai_engine_alerts_total[1h]))", "legendFormat": "alerts/1h" } ]
    },
    {
      "type": "stat", "title": "Weekly AI budget used",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": {
        "unit": "percentunit", "decimals": 0, "min": 0, "max": 1.2,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "orange", "value": 0.8 },
          { "color": "red", "value": 1 } ] } } },
      "targets": [ { "expr": "max(ai_cost_budget_used_ratio)", "legendFormat": "budget used" } ]
    },
    {
      "type": "timeseries", "title": "Gateway outcomes (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum by (outcome) (rate(ai_gateway_requests_total[5m]))", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "type": "timeseries", "title": "Gateway latency p50/p95 (AI contribution to page)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "s",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 0.8 } ] } } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by (le) (rate(ai_gateway_latency_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_gateway_latency_seconds_bucket[5m])))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "timeseries", "title": "Alerts emitted by severity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (severity) (increase(ai_engine_alerts_total[10m]))", "legendFormat": "{{severity}}" }
      ]
    },
    {
      "type": "timeseries", "title": "Detection latency p95 (SLA ≤ 3 min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "fieldConfig": { "defaults": { "unit": "s",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null }, { "color": "red", "value": 180 } ] } } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_engine_detection_latency_seconds_bucket[30m])))", "legendFormat": "p95 detect" }
      ]
    },
    {
      "type": "stat", "title": "Cache hit ratio (cost + latency lever)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1,
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null }, { "color": "orange", "value": 0.3 }, { "color": "green", "value": 0.6 } ] } } },
      "targets": [ { "expr": "max(ai_cache_hit_ratio)", "legendFormat": "hit ratio" } ]
    },
    {
      "type": "timeseries", "title": "Guardrail blocks (spike ⇒ llmInaccurateResponse?)",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "sum by (reason) (increase(ai_guardrail_block_total[10m]))", "legendFormat": "{{reason}}" }
      ]
    },
    {
      "type": "timeseries", "title": "AI cost by feature (USD, 7d increase)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 21 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        { "expr": "sum by (feature) (increase(ai_cost_usd_total[7d]))", "legendFormat": "{{feature}}" }
      ]
    }
  ]
}
