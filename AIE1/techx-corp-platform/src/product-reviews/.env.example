# Thư mục chạy local: AIE1/techx-corp-platform/src/product-reviews/
# Sao chép file này thành '.env' và điền các giá trị thật của bạn.

OTEL_SERVICE_NAME=product-reviews
PRODUCT_REVIEWS_PORT=8085
DB_CONNECTION_STRING=host=localhost user=otelu password=otelp dbname=demo
PRODUCT_CATALOG_ADDR=localhost:8081
FLAGD_HOST=localhost
FLAGD_PORT=8013
LLM_HOST=localhost
LLM_PORT=8000

# Cấu hình AI Engine
LLM_PROVIDER=bedrock
LLM_MODEL=amazon.nova-lite-v1:0
AWS_REGION=us-east-1

# AWS Credentials phục vụ gọi Bedrock (bắt buộc nếu máy chưa login aws cli)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
